{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "lib": [
      "ESNext.AsyncIterable"
    ],
    "typeRoots": [
      "./node_modules/@types/",
      "./src/types"
    ],
    "incremental": true,
    "outDir": "./dist",
    "strict": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "pretty": true,
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@config/*": [
        "./src/config/*"
      ],
      "@test/*": [
        "./src/__test__/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/*.test.ts", // 테스트 파일 제외
    "src/**/*.spec.ts", // 스펙 파일 제외
    "src/temp/**/*", // 임시 폴더 제외
    "src/generated/**/*"
  ]
}