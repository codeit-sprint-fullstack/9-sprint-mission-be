{
  "name": "codeit-backend-server",
  "version": "1.0.1",
  "description": "panda-express-server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "type-check": "tsc",
    "dev": "tsx watch --env-file=./env/.env.development src/server.js",
    "start": "node --enable-source-maps dist/src/server.js",
    "build": "npx swc src -d dist && node dist/src/swagger.js",
    "format": "prettier --cache --write src/**/*.js",
    "lint": "eslint --cache .",
    "prisma": "node --env-file=./env/.env.development node_modules/prisma/build/index.js",
    "db:push": "npm run prisma -- db push",
    "migrate:dev": "npm run prisma -- migrate dev",
    "migrate:deploy": "npm run prisma -- migrate deploy",
    "migrate:reset": "npm run prisma -- migrate reset",
    "generate": "npm run prisma generate",
    "studio": "npm run prisma -- studio",
    "test": "dotenv -e ./env/.env.test -- node --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles",
    "test:watch": "dotenv -e ./env/.env.test -- jest --watch"
  },
  "lint-staged": {
    "**/*.(js.jsx.ts.tsx)": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rklpoi5678/9-sprint-mission-be.git"
  },
  "keywords": [
    "express-misson"
  ],
  "author": {
    "name": "youngi-kim",
    "email": "rklpoi5678@naver.com",
    "url": "https://github.com/rklpoi5678"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rklpoi5678/9-sprint-mission-be/issues"
  },
  "engines": {
    "node": ">=24.x",
    "npm": ">=11.x"
  },
  "homepage": "https://github.com/rklpoi5678/9-sprint-mission-be#readme",
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cuid": "^3.0.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-jwt": "^8.5.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prisma": "^7.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  }
}