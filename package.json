  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rklpoi5678/9-sprint-mission-be/issues"
  },
  "homepage": "https://github.com/rklpoi5678/9-sprint-mission-be#readme",
  "dependencies": {
    "express": "^5.1.0",
    "mongoose": "^8.18.2",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.11",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2"
  }
}